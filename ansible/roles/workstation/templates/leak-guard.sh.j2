#!/usr/bin/env bash
# Leak-guard — block PII from entering git history. Managed by Ansible
# (roles/workstation). Used as a pre-commit hook: scans the staged diff against
# the denylist and fails the commit on any match.
set -euo pipefail
DENYLIST="{{ workstation_leak_guard_dir }}/denylist.txt"
[[ -f "$DENYLIST" ]] || exit 0

staged="$(git diff --cached -U0 2>/dev/null || true)"
[[ -n "$staged" ]] || exit 0

hit=0
while IFS= read -r pat; do
  [[ -z "$pat" || "$pat" == \#* ]] && continue
  if grep -nEi -- "$pat" <<<"$staged" >/dev/null 2>&1; then
    echo "leak-guard: staged change matches blocked pattern: $pat" >&2
    hit=1
  fi
done < "$DENYLIST"

if [[ $hit -ne 0 ]]; then
  echo "leak-guard: commit blocked. Remove the flagged content or use placeholders." >&2
  exit 2
fi
exit 0
