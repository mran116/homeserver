{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "logs",
      "title": "Logs — $container",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 26, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=~\"$job\", container=~\"$container\"} |~ `(?i)$search`",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["homestack"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "custom",
        "label": "Source",
        "query": "docker,journal",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true
      },
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(container)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "Logs — all containers + host",
  "uid": "homestack-logs"
}
