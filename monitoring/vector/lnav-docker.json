{
  "$schema": "https://lnav.org/schemas/format-v1.schema.json",
  "docker_vector_ndjson": {
    "title": "Docker container logs (Vector ndjson)",
    "description": "Container logs shipped by Vector's docker_logs source as ndjson under CONFIG_PATH/logs. Install once: lnav -i monitoring/vector/lnav-docker.json",
    "json": true,
    "file-pattern": ".*/logs/\\d{4}-\\d{2}-\\d{2}/.*\\.log$",
    "timestamp-field": "timestamp",
    "body-field": "message",
    "level-field": "stream",
    "level": {
      "error": "stderr"
    },
    "line-format": [
      { "field": "__timestamp__" },
      " ",
      { "field": "container_name", "min-width": 16, "max-width": 16, "overflow": "truncate" },
      " | ",
      { "field": "message" }
    ],
    "value": {
      "container_name": { "kind": "string", "identifier": true },
      "image": { "kind": "string", "identifier": true },
      "stream": { "kind": "string" },
      "message": { "kind": "string" }
    }
  }
}
