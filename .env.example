# =============================================================================
# MASTER ENV TEMPLATE
# Copy this to .env and fill in your values:   cp .env.example .env
# Store actual secrets in Vaultwarden.
# NEVER commit .env to Git — blocked by .gitignore.
# =============================================================================

# =============================================================================
# SYSTEM
# =============================================================================
SERVER_IP=192.168.1.100          # Your server's local IP address
PUID=1000                        # Run: id -u
PGID=1000                        # Run: id -g
TZ=America/Chicago               # TZ database format
UMASK=002

# =============================================================================
# PATHS
# =============================================================================
CONFIG_PATH=/opt/docker/data     # App config / bind mounts
MEDIA_PATH=/mnt/media            # Movies, TV, music, anime, books
PHOTOS_PATH=/mnt/photos          # Immich photo/video library
DOCS_PATH=/mnt/documents         # Paperless document storage

# =============================================================================
# PORTS — single source of truth for every host port
# Homepage's services.yaml reads these via HOMEPAGE_VAR_* aliases that
# dashboard/docker-compose.yml forwards. Do NOT duplicate values.
# =============================================================================

# Infrastructure
NPM_PORT=81

# Management / Dashboard
HOMEPAGE_PORT=3000
DOCKGE_PORT=5001

# Monitoring
UPTIME_KUMA_PORT=3001
DOZZLE_PORT=3002
DIUN_PORT=8085

# Media
BITTORRENT_PORT=8080
SABNZBD_PORT=8081
JELLYFIN_PORT=8096
SEERR_PORT=5055
RADARR_PORT=7878
SONARR_PORT=8989
LIDARR_PORT=8686
WHISPARR_PORT=6969
PROWLARR_PORT=9696
BAZARR_PORT=6767
FLARESOLVERR_PORT=8191
KAVITA_PORT=5000
RECOMMENDARR_PORT=4534
NAVIDROME_PORT=4533

# Household
MEALIE_PORT=9925
KITCHENOWL_PORT=9926
DONETICK_PORT=9927
ACTUAL_PORT=9928

# Records
PAPERLESS_PORT=9929
STIRLING_PORT=9931
DOCUSEAL_PORT=9932

# Vaultwarden
VAULTWARDEN_PORT=9930

# Cloud
IMMICH_PORT=2283
MATRIX_PORT=8008

# =============================================================================
# SECRETS — store ALL values below in Vaultwarden under "Homeserver Secrets"
#
# Each secret flows ONE of two ways — know which before you fill it:
#   [SETS]   the value here configures the app (the app/DB adopts it). DB
#            passwords + admin tokens. bootstrap.sh auto-generates blanks.
#            !! For an EXISTING database, you MUST use the password it was
#               created with — a new value will not match and the app won't
#               connect. bootstrap detects existing DBs and leaves them blank.
#   [LOGIN]  the app owns the value; you create it in the app, then paste it
#            here so Homepage/Gluetun can authenticate. Wrong value only
#            breaks a widget — never your data. (run ./scripts/harvest-keys.sh)
# =============================================================================

# VPN — WireGuard / ProtonVPN   [LOGIN: from your VPN provider]
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
VPN_SERVER_COUNTRIES=
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=protonvpn

# Download client credentials   [LOGIN: set in qBittorrent's WebUI, then match here]
APP_USERNAME=
APP_PASSWORD=

# *arr API keys   [LOGIN: each app → Settings → General → Security, then paste here]
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
WHISPARR_API_KEY=

# Diun — Docker image update notifier (posts to Home Assistant webhook).
# Create webhook in HA: Settings → Automations → New → Webhook trigger.
# Format:  http://<ha-vm-ip>:8123/api/webhook/<your-webhook-id>
DIUN_NOTIF_WEBHOOK_URL=

# Gitea (Phase 3 — uncomment when ready to enable in devops/)
# GITEA_HTTP_PORT=3030
# GITEA_SSH_PORT=222
# GITEA_DB_PASSWORD=
# GITEA_RUNNER_TOKEN=

# Nginx Proxy Manager database   [SETS: first init only; existing DB must match]
NPM_DB_ROOT_PASSWORD=
NPM_DB_PASSWORD=

# Vaultwarden   [SETS: token gates the admin panel] — openssl rand -base64 48
# Recommend leaving signups DISABLED; flip to true only for first account.
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_ADMIN_TOKEN=

# Paperless   [SETS: DB password = first init only; admin user/pass created on
#              first run only — changing later does nothing, set it in-app]
PAPERLESS_DB_PASSWORD=
PAPERLESS_SECRET_KEY=            # Generate with: openssl rand -base64 48
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=

# Immich   [SETS: first init only; existing DB must match]
IMMICH_DB_PASSWORD=

# DocuSeal — uncomment when domain and SMTP are ready
# DOCUSEAL_SECRET_KEY=
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# Matrix — uncomment when domain is ready
# MATRIX_SERVER_NAME=yourdomain.com

# Borgmatic — uncomment when offsite backup is ready
# BORG_PASSPHRASE=

# Tailscale — get auth key at: login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TAILSCALE_HOSTNAME=homeserver
TAILSCALE_SUBNET=192.168.1.0/24

# Cloudflare Tunnel — get token at: cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# APP API KEYS & CREDENTIALS (used by Homepage widgets)   [LOGIN — all of these]
# You create/find each value IN THE APP, then paste it here so Homepage can log
# in and read stats. These are read-only auth — a wrong value only blanks a
# widget, it can never break or corrupt the app. Gather them after each app is
# up:  ./scripts/harvest-keys.sh
#
# Plain, un-prefixed names — set each once here. dashboard/docker-compose.yml
# forwards them to Homepage as HOMEPAGE_VAR_* (Homepage requires that prefix in
# its config; we add it there, not here, so there's no duplication).
# =============================================================================
JELLYFIN_API_KEY=
SEERR_API_KEY=
SABNZBD_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
MEALIE_API_KEY=
IMMICH_API_KEY=
NAVIDROME_USER=
NAVIDROME_TOKEN=
NAVIDROME_SALT=
KAVITA_USER=
KAVITA_PASSWORD=
NPM_EMAIL=
NPM_PASSWORD=
