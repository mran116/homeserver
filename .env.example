# =============================================================================
# MASTER ENV TEMPLATE
# Copy this to .env and fill in your values:   cp .env.example .env
# Store actual secrets in Vaultwarden.
# NEVER commit .env to Git — blocked by .gitignore.
# =============================================================================

# =============================================================================
# SYSTEM
# =============================================================================
SERVER_IP=192.168.1.100          # Your server's local IP address
PUID=1000                        # Run: id -u
PGID=1000                        # Run: id -g
TZ=America/Chicago               # TZ database format
UMASK=002

# =============================================================================
# PATHS
# =============================================================================
CONFIG_PATH=/opt/docker/data     # App config / bind mounts
MEDIA_PATH=/mnt/media            # Movies, TV, music, anime, books
PHOTOS_PATH=/mnt/photos          # Immich photo/video library
DOCS_PATH=/mnt/documents         # Paperless document storage

# =============================================================================
# PORTS — single source of truth for every host port
# Homepage's services.yaml reads these via HOMEPAGE_VAR_* aliases that
# dashboard/docker-compose.yml forwards. Do NOT duplicate values.
# =============================================================================

# Infrastructure
NPM_PORT=81

# Management / Dashboard
HOMEPAGE_PORT=3000
DOCKGE_PORT=5001

# Monitoring
UPTIME_KUMA_PORT=3001
DOZZLE_PORT=3002
NOTIFIARR_PORT=5454
DIUN_PORT=8085

# Media
BITTORRENT_PORT=8080
SABNZBD_PORT=8081
JELLYFIN_PORT=8096
SEERR_PORT=5055
RADARR_PORT=7878
SONARR_PORT=8989
LIDARR_PORT=8686
WHISPARR_PORT=6969
PROWLARR_PORT=9696
BAZARR_PORT=6767
FLARESOLVERR_PORT=8191
KAVITA_PORT=5000
RECOMMENDARR_PORT=4534
NAVIDROME_PORT=4533

# Household
MEALIE_PORT=9925
KITCHENOWL_PORT=9926
DONETICK_PORT=9927
ACTUAL_PORT=9928

# Records
PAPERLESS_PORT=9929
STIRLING_PORT=9931
DOCUSEAL_PORT=9932

# Vaultwarden
VAULTWARDEN_PORT=9930

# Cloud
IMMICH_PORT=2283
MATRIX_PORT=8008

# Automation
N8N_PORT=5678

# =============================================================================
# SECRETS — store ALL values below in Vaultwarden under "Homeserver Secrets"
# =============================================================================

# VPN — WireGuard / ProtonVPN
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
VPN_SERVER_COUNTRIES=
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=protonvpn

# Download client credentials
APP_USERNAME=
APP_PASSWORD=

# *arr API keys (find in each app under Settings → General after first run)
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
WHISPARR_API_KEY=

# Notifiarr — sign up at notifiarr.com
NOTIFIARR_API_KEY=

# Diun — notification target (Discord/Telegram/Slack/Gotify/etc.)
# See https://crazymax.dev/diun/notif/ for full list
DIUN_NOTIF_WEBHOOK_URL=

# Nginx Proxy Manager database
NPM_DB_ROOT_PASSWORD=
NPM_DB_PASSWORD=

# Vaultwarden — generate admin token with: openssl rand -base64 48
# Recommend leaving signups DISABLED; flip to true only for first account.
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_ADMIN_TOKEN=

# Paperless
PAPERLESS_DB_PASSWORD=
PAPERLESS_SECRET_KEY=            # Generate with: openssl rand -base64 48
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=

# Immich
IMMICH_DB_PASSWORD=

# DocuSeal — uncomment when domain and SMTP are ready
# DOCUSEAL_SECRET_KEY=
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# Matrix — uncomment when domain is ready
# MATRIX_SERVER_NAME=yourdomain.com

# n8n — uncomment when ready
# N8N_USER=
# N8N_PASSWORD=

# Borgmatic — uncomment when offsite backup is ready
# BORG_PASSPHRASE=

# Tailscale — get auth key at: login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TAILSCALE_HOSTNAME=homeserver
TAILSCALE_SUBNET=192.168.1.0/24

# Cloudflare Tunnel — get token at: cloudflare.com → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# HOMEPAGE WIDGET CREDENTIALS
# Only secrets/credentials live here — ports are forwarded from the
# block above via dashboard/docker-compose.yml (no duplication).
# =============================================================================
HOMEPAGE_VAR_DOCKGE_API_KEY=
HOMEPAGE_VAR_JELLYFIN_API_KEY=
HOMEPAGE_VAR_SEERR_API_KEY=
HOMEPAGE_VAR_NAVIDROME_USER=
HOMEPAGE_VAR_NAVIDROME_TOKEN=
HOMEPAGE_VAR_NAVIDROME_SALT=
HOMEPAGE_VAR_KAVITA_USER=
HOMEPAGE_VAR_KAVITA_PASSWORD=
HOMEPAGE_VAR_SABNZBD_API_KEY=
HOMEPAGE_VAR_PROWLARR_API_KEY=
HOMEPAGE_VAR_BAZARR_API_KEY=
HOMEPAGE_VAR_MEALIE_API_KEY=
HOMEPAGE_VAR_NPM_EMAIL=
HOMEPAGE_VAR_NPM_PASSWORD=
HOMEPAGE_VAR_IMMICH_API_KEY=
