# =============================================================================
# SECRETS — never commit
# =============================================================================
.env
.env.*
!.env.example
*.local
*.private
.envrc

# Ansible — real (PII-bearing) inventory + host vars stay local; ship examples
ansible/inventory/hosts.yml
ansible/host_vars/*.yml
!ansible/host_vars/example.yml
ansible/*.retry
ansible/collections/

# =============================================================================
# CERTIFICATES & KEYS — never commit
# =============================================================================
*.pem
*.crt
*.cert
*.p12
*.pfx
*.ca-bundle
*.cer
id_rsa
id_ed25519
authorized_keys
known_hosts

# =============================================================================
# RUNTIME CONFIG / STATE — never commit
# =============================================================================
**/letsencrypt/
**/certs/
**/ssl/
**/tls/
**/secrets/
*.sqlite
*.sqlite3
*.db

# =============================================================================
# COMPOSE OVERRIDES — local-only customizations
# =============================================================================
compose.override.yml
docker-compose.override.yml

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.pyc

# =============================================================================
# OS / EDITOR
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.idea/
*.swp
*.swo

# Ignore personal VS Code files but keep shared project settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# =============================================================================
# BACKUPS / LOGS
# =============================================================================
*.bak
*.backup
*.old
*.orig
*.log

# =============================================================================
# PRIVATE LOCAL NOTES — never published (personal roadmap, scratch notes)
# =============================================================================
*.local.md
ROADMAP.local.md
# Private Homepage overlays (personal bookmarks etc.) — appended onto live config
# by make-dirs.sh, never committed
*.local.yaml
