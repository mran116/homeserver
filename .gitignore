# =============================================================================
# SECRETS — never commit
# =============================================================================
.env
.env.*
!.env.example
*.local
*.private
.envrc

# =============================================================================
# CERTIFICATES & KEYS — never commit
# =============================================================================
*.pem
*.crt
*.cert
*.p12
*.pfx
*.ca-bundle
*.cer
id_rsa
id_ed25519
authorized_keys
known_hosts

# =============================================================================
# RUNTIME CONFIG / STATE — never commit
# =============================================================================
**/letsencrypt/
**/certs/
**/ssl/
**/tls/
**/secrets/
*.sqlite
*.sqlite3
*.db

# =============================================================================
# COMPOSE OVERRIDES — local-only customizations
# =============================================================================
compose.override.yml
docker-compose.override.yml

# =============================================================================
# OS / EDITOR
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.vscode/settings.json
.idea/
*.swp
*.swo

# =============================================================================
# BACKUPS
# =============================================================================
*.bak
*.backup
*.old
*.orig
